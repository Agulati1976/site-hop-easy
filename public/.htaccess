# Hostinger / Apache SPA rewrite — every non-file URL serves index.html
# so deep links like /events/abc work on refresh.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Don't rewrite real files or directories
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Send everything else to the SPA entry
  RewriteRule . /index.html [L]
</IfModule>

# Long-lived caching for hashed assets
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|woff2?|ttf|otf|png|jpg|jpeg|webp|avif|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(html)$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>
</IfModule>

# Gzip
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

# --- 301 redirects from old WordPress URLs go here ---
# Example:
# Redirect 301 /old-page/ /new-page
